# ===== 主模型（OpenAI-compatible chat.completions，agent 必需）=====
CHAT_BASE_URL=https://example.com/v1
CHAT_API_KEY=sk-...
CHAT_MODEL=your-chat-model

# ===== Embedding（可选；不配则 semantic_search 退化为 FTS-only）=====
EMBED_BASE_URL=https://example.com/v1
EMBED_API_KEY=sk-...
EMBED_MODEL=your-embedding-model
# 初始建表维度；ingest 会按接口实际返回维度自动重建向量表。
# Qwen/Qwen3-Embedding-8B 常见返回维度为 4096。
EMBED_DIM=4096

# ===== 可选：索引期摘要前缀 =====
# SUMMARY_MODEL=your-chat-model
