# Main chat model. Required for the interactive agent.
CHAT_BASE_URL=https://example.com/v1
CHAT_API_KEY=sk-...
CHAT_MODEL=your-chat-model
# CHAT_TIMEOUT=300
# CHAT_MAX_RETRIES=3
# Local retry attempts for ingest API failures.
# This is the total attempt count including the first request.
# CHAT_LOCAL_RETRIES=3
# CHAT_RETRY_SLEEP=1

# Local SQLite database. Keep this under runtime/ so it stays out of Git.
CHAT_DB=runtime/chat.db

# Embeddings are optional. Without them, semantic_search falls back to FTS-only.
EMBED_BASE_URL=https://example.com/v1
EMBED_API_KEY=sk-...
EMBED_MODEL=your-embedding-model
# The ingest command will rebuild the vector table if the actual dimension differs.
# Qwen/Qwen3-Embedding-8B commonly returns 4096 dimensions.
EMBED_DIM=4096
# EMBED_TIMEOUT=90
# EMBED_MAX_RETRIES=0
# Local retry attempts for ingest API failures.
# This is the total attempt count including the first request.
# EMBED_LOCAL_RETRIES=3
# EMBED_RETRY_SLEEP=1

# Optional summaries during indexing.
# SUMMARY_MODEL=your-chat-model
# SUMMARY_WORKERS=2
# SUMMARY_BATCH_SIZE=4
# SUMMARY_MAX_CHARS=3000
# SUMMARY_FALLBACK_CHARS=1200

# Optional ingest tuning. Command-line flags override these defaults.
# EMBED_WORKERS=4
# EMBED_BATCH_SIZE=32
# PROGRESS_EVERY=50
# PROGRESS_INTERVAL=15
# By default, summary/embedding model or API errors stop ingest.
# Set INGEST_KEEP_GOING=true or add --keep-going to continue processing other batches.
# Use --stop-on-error for a one-off run that ignores INGEST_KEEP_GOING=true.
# INGEST_KEEP_GOING=false
