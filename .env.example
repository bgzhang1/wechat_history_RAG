# Main chat model. Required for the interactive agent.
# Replace every placeholder below; example.com, sk-..., and your-* are treated as unconfigured.
CHAT_BASE_URL=https://example.com/v1
CHAT_API_KEY=sk-...
CHAT_MODEL=your-chat-model
# CHAT_TIMEOUT=300
# CHAT_MAX_RETRIES=3
# Local retry attempts for ingest API failures.
# This is the total attempt count including the first request.
# CHAT_LOCAL_RETRIES=3
# CHAT_RETRY_SLEEP=1

# Local SQLite database. Keep this under runtime/ so it stays out of Git.
CHAT_DB=runtime/chat.db
# Persistent web chat sessions. Keep this under runtime/ so it stays out of Git.
# BACKEND_CHAT_DB=runtime/backend_chat.db
# Non-secret runtime settings saved by the settings page.
# BACKEND_SETTINGS_FILE=runtime/backend_settings.json

# Embeddings are optional. Without them, semantic_search falls back to FTS-only.
EMBED_BASE_URL=https://example.com/v1
EMBED_API_KEY=sk-...
EMBED_MODEL=your-embedding-model
# The ingest command will rebuild the vector table if the actual dimension differs.
# Qwen/Qwen3-Embedding-8B commonly returns 4096 dimensions.
EMBED_DIM=4096
# EMBED_TIMEOUT=90
# EMBED_MAX_RETRIES=0
# Local retry attempts for ingest API failures.
# This is the total attempt count including the first request.
# EMBED_LOCAL_RETRIES=3
# EMBED_RETRY_SLEEP=1

# Optional summaries during indexing.
# SUMMARY_MODEL=your-chat-model
# SUMMARY_WORKERS=2
# SUMMARY_BATCH_SIZE=4
# SUMMARY_MAX_CHARS=3000
# SUMMARY_FALLBACK_CHARS=1200

# Optional ingest tuning. Command-line flags override these defaults.
# EMBED_WORKERS=4
# EMBED_BATCH_SIZE=32
# PROGRESS_EVERY=50
# PROGRESS_INTERVAL=15
# By default, summary/embedding model or API errors stop ingest.
# Set INGEST_KEEP_GOING=true or add --keep-going to continue processing other batches.
# Use --stop-on-error for a one-off run that ignores INGEST_KEEP_GOING=true.
# INGEST_KEEP_GOING=false
# Maximum uploaded JSON size in MB and in-memory task history retained by the backend.
# INGEST_MAX_UPLOAD_MB=512
# INGEST_MAX_TASKS=100
# In-memory ingest logs are capped to prevent one noisy task from consuming too much RAM.
# INGEST_MAX_TASK_LOG_LINES=5000
# INGEST_MAX_TASK_LOG_LINE_CHARS=4000

# Backend diagnostics log. The JSONL log is stored locally under runtime/ by default.
# BACKEND_LOG_FILE=runtime/backend.log.jsonl
# BACKEND_LOG_MAX_MB=10

# Backend server and browser access.
# HOST=0.0.0.0
# PORT=8000
# Local Vite ports 5173-5180 are allowed by default. Add deployed frontend origins here.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend build-time API endpoint. Usually optional in local dev: the frontend
# defaults to the current page hostname on port 8000, e.g. http://127.0.0.1:8000.
# Set this in frontend/.env when the backend uses a different host or port.
# Use VITE_API_BASE= for same-origin /api deployments behind a reverse proxy.
# VITE_API_BASE=http://localhost:8000
