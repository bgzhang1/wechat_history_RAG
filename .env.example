# ===== 主模型（OpenAI-compatible chat.completions，agent 必需）=====
CHAT_BASE_URL=https://example.com/v1
CHAT_API_KEY=sk-...
CHAT_MODEL=your-chat-model
# CHAT_TIMEOUT=90
# CHAT_MAX_RETRIES=0

# ===== Embedding（可选；不配则 semantic_search 退化为 FTS-only）=====
EMBED_BASE_URL=https://example.com/v1
EMBED_API_KEY=sk-...
EMBED_MODEL=your-embedding-model
# 初始建表维度；ingest 会按接口实际返回维度自动重建向量表。
# Qwen/Qwen3-Embedding-8B 常见返回维度为 4096。
EMBED_DIM=4096
# EMBED_TIMEOUT=90
# EMBED_MAX_RETRIES=0
# EMBED_LOCAL_RETRIES=1
# EMBED_RETRY_SLEEP=1

# ===== 可选：索引期摘要前缀 =====
# SUMMARY_MODEL=your-chat-model
# SUMMARY_BATCH_SIZE=4
# SUMMARY_MAX_CHARS=3000
# SUMMARY_FALLBACK_CHARS=1200

# ===== 可选：ingest 进度显示 =====
# PROGRESS_EVERY=50
# PROGRESS_INTERVAL=15
# 默认摘要/embedding 遇到模型/API 错误会立即停止；命令行加 --keep-going 可继续处理其余批次。
